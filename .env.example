# Copy to .env and fill in. LIGHTNING loads these via python-dotenv at import time.
# Pick ONE auth path: direct Anthropic API or AWS Bedrock.

# --- Option A: direct Anthropic API ---
# ANTHROPIC_API_KEY=sk-ant-...

# --- Option B: AWS Bedrock (Claude via Bedrock) ---
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_REGION=us-east-1
# Optional: force Bedrock even if ANTHROPIC_API_KEY is also set.
# LIGHTNING_USE_BEDROCK=1

# Optional: override the default model. Format differs by backend:
#   Anthropic direct: claude-sonnet-4-5
#   Bedrock:          us.anthropic.claude-3-5-sonnet-20241022-v2:0
# LIGHTNING_MODEL=
